# Meta WhatsApp Cloud API
META_PHONE_NUMBER_ID=         # isi setelah SIM terdaftar
META_ACCESS_TOKEN=              # permanent token dari Meta App
META_VERIFY_TOKEN=  # bebas, kamu yang tentukan

# Google Gemini
GEMINI_API_KEY=                 # dari https://aistudio.google.com/apikey

# Supabase
NEXT_PUBLIC_SUPABASE_URL=       # dari Supabase dashboard
NEXT_PUBLIC_SUPABASE_ANON_KEY=  # dari Supabase dashboard
SUPABASE_SERVICE_ROLE_KEY=      # dari Supabase dashboard (JANGAN expose ke frontend)

# Midtrans Sandbox
MIDTRANS_SERVER_KEY=            # dari https://dashboard.midtrans.com
MIDTRANS_CLIENT_KEY=            # dari https://dashboard.midtrans.com
MIDTRANS_IS_PRODUCTION=

# Auth
JWT_SECRET=                     # generate: openssl rand -base64 32
NEXT_PUBLIC_APP_URL=